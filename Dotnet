@model List<Course>

<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name = "viewport" content="width=device-width, initial-scale1.0">
        <title>Document</title>

    </head>
    <body>
        @foreach(var  kurs in Model){
            <p>course/index page</p>
            <p>Id:@kurs.Id</p>
            <p>@kurs.Title</p>
            <p>description: @kurs.Description</p>
            <img src="~/img/@kurs.Image"/>
        }
        
    </body>
</html>
